# ~/.zshrc

# Shared environment (PATH, asdf, pnpm, go — also used by .bashrc)
DEVBOX_DIR="${DEVBOX_DIR:-$HOME/devbox}"
source $DEVBOX_DIR/dotfiles/shellenv

# Zsh-specific environment
export BUNDLER_EDITOR="nvim"
export MANPAGER="less -X"
export HOMEBREW_CASK_OPTS="--appdir=/Applications"
export SOURCE_ANNOTATION_DIRECTORIES="spec"
export DISABLE_AUTO_TITLE=true
export _Z_OWNER=$USER

# Zsh options
setopt auto_cd
setopt append_history
setopt inc_append_history
setopt hist_ignore_dups
setopt hist_ignore_space
setopt hist_expire_dups_first
setopt hist_verify

WORDCHARS=${WORDCHARS//\//}

cdpath=($HOME/Code $HOME/devbox $HOME/Developer $HOME/Sites $HOME/Dropbox $HOME)

# History configuration
HISTSIZE=1000000
SAVEHIST=1000000
HISTFILE=~/.zsh_history
HIST_STAMPS="yyyy-mm-dd"

# Load modular configuration
source $DEVBOX_DIR/dotfiles/zsh/aliases
source $DEVBOX_DIR/dotfiles/zsh/functions
source $DEVBOX_DIR/dotfiles/zsh/z.sh

# Load completions
autoload -Uz compinit
compinit

# Starship prompt
if command -v starship &> /dev/null; then
  eval "$(starship init zsh)"
fi

# Zap plugin manager
[ -f "$HOME/.local/share/zap/zap.zsh" ] && source "$HOME/.local/share/zap/zap.zsh"

# Plugins
plug "zsh-users/zsh-autosuggestions"
plug "zsh-users/zsh-syntax-highlighting"
plug "zsh-users/zsh-history-substring-search"

# Bind keys for history substring search
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down
bindkey '^[OA' history-substring-search-up
bindkey '^[OB' history-substring-search-down

# Word navigation (cross-terminal compatibility)
bindkey '^[[1;3D' backward-word    # Alt+Left
bindkey '^[[1;3C' forward-word     # Alt+Right
bindkey '^[b' backward-word        # Option+b / ESC+b
bindkey '^[f' forward-word         # Option+f / ESC+f
bindkey '^[^?' backward-kill-word  # Option+Delete

# fzf key bindings and fuzzy completion
command -v fzf &> /dev/null && source <(fzf --zsh)

# Remove duplicate PATH entries
typeset -U PATH path

# Include local settings
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
